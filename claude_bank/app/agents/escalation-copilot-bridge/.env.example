# Environment Configuration Template
# Copy this file to .env and fill in your values

# ==========================================
# Azure AD Configuration (REQUIRED)
# ==========================================

# Get these from Azure Portal > Azure Active Directory > App registrations
AZURE_CLIENT_ID=your-application-client-id
AZURE_CLIENT_SECRET=your-application-client-secret
AZURE_TENANT_ID=your-tenant-id

# ==========================================
# Excel File Configuration (REQUIRED)
# ==========================================

# Option 1: Use Drive ID directly (recommended for SharePoint/OneDrive for Business)
EXCEL_DRIVE_ID=your-drive-id
EXCEL_FILE_PATH=/tickets.xlsx

# Option 2: Use SharePoint Site (alternative)
# EXCEL_SITE_ID=your-sharepoint-site-id
# EXCEL_FILE_PATH=/tickets.xlsx

# Option 3: Use User's OneDrive (alternative)
# EXCEL_USER_ID=your-user-id-or-email@example.com
# EXCEL_FILE_PATH=/tickets.xlsx

# Excel table name (must match what you created in Excel)
EXCEL_TABLE_NAME=TicketsTable

# ==========================================
# Email Configuration (REQUIRED)
# ==========================================

# The email address that will send notifications
EMAIL_SENDER_ADDRESS=your-email@example.com
EMAIL_SENDER_NAME=BankX Support Team

# ==========================================
# Service Configuration
# ==========================================

# Port for A2A server (default: 9006)
A2A_SERVER_PORT=9006

# Agent Registry URL
AGENT_REGISTRY_URL=http://localhost:9000

# Register with agent registry on startup
REGISTER_WITH_REGISTRY=true

# ==========================================
# Logging
# ==========================================

LOG_LEVEL=INFO

# ==========================================
# Default Values (optional)
# ==========================================

DEFAULT_TICKET_PRIORITY=normal
DEFAULT_TICKET_STATUS=Open
DEFAULT_CUSTOMER_ID=CUST-UNKNOWN
